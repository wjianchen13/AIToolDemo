<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#151515"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".test1.TestActivity1">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="LTR 进度 50%"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <com.example.aitooldemo.test1.BadgeProgressView
        android:id="@+id/badgeProgressLtr"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="12dp" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Test1"
        android:onClick="onTest1"
        android:textAllCaps="false"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:text="RTL 进度 50%（从右侧开始）"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <com.example.aitooldemo.test1.BadgeProgressView
        android:id="@+id/badgeProgressRtl"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="12dp"
        android:layoutDirection="rtl" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Test2"
        android:onClick="onTest2"
        android:textAllCaps="false"
        />

</LinearLayout>
